<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" styleClass="root" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.school.management.controller.LoginController">
    <stylesheets>
        <URL value="@../css/styles.css" />
    </stylesheets>
    
    <children>
        <VBox alignment="CENTER" fillWidth="false" spacing="25.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <VBox alignment="CENTER" spacing="10.0" style="-fx-padding: 0 0 10 0;">
                    <children>
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="title-text" text="IQRA ACADEMY" textAlignment="CENTER" />
                        <Label styleClass="subtitle-text" text="Learning Management &amp; School Portal" />
                    </children>
                </VBox>
                
                <VBox alignment="CENTER_LEFT" prefWidth="380.0" spacing="20.0" styleClass="glass-card">
                    <padding>
                        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
                    </padding>
                    <children>
                        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="Sign In" />
                        <Label styleClass="body-text" text="Enter your ID or Admin Email to log in" />
                        
                        <VBox spacing="8.0">
                            <children>
                                <Label styleClass="body-text" text="Username / Unique ID / Email" />
                                <TextField fx:id="usernameField" prefHeight="45.0" prefWidth="300.0" promptText="e.g. STD101, TCH201, or admin@school.com" />
                            </children>
                        </VBox>
                        
                        <VBox spacing="8.0">
                            <children>
                                <Label styleClass="body-text" text="Password" />
                                <PasswordField fx:id="passwordField" prefHeight="45.0" prefWidth="300.0" promptText="••••••••" />
                            </children>
                        </VBox>
                        
                        <Label fx:id="errorLabel" style="-fx-text-fill: #f87171; -fx-font-size: 13px;" visible="false" wrapText="true" />
                        
                        <Button fx:id="loginButton" defaultButton="true" mnemonicParsing="false" onAction="#handleLogin" prefHeight="45.0" prefWidth="300.0" styleClass="btn-primary" text="Log In" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
