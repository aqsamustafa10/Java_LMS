<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="768.0" prefWidth="1280.0" styleClass="root" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.school.management.controller.StudentController">
    <stylesheets>
        <URL value="@../css/styles.css" />
    </stylesheets>
    
    <children>
        <HBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <!-- Sidebar Nav -->
                <VBox prefWidth="250.0" styleClass="sidebar">
                    <children>
                        <!-- Sidebar Header -->
                        <VBox alignment="CENTER_LEFT" spacing="5.0">
                            <padding>
                                <Insets bottom="30.0" left="25.0" right="25.0" top="35.0" />
                            </padding>
                            <children>
                                <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="title-text" style="-fx-font-size: 20px;" text="IQRA LMS" />
                                <Label fx:id="lblSidebarStudentId" styleClass="text-muted" text="Student Portal" />
                            </children>
                        </VBox>
                        
                        <!-- Nav Buttons -->
                        <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                            <padding>
                                <Insets left="15.0" right="15.0" />
                            </padding>
                            <children>
                                <Button fx:id="btnNavPortal" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#switchTab" styleClass="btn-nav, btn-nav-active" text="My Profile" />
                                <Button fx:id="btnNavAttendance" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#switchTab" styleClass="btn-nav" text="Attendance Records" />
                                <Button fx:id="btnNavAssessments" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#switchTab" styleClass="btn-nav" text="Quizzes &amp; Exams" />
                            </children>
                        </VBox>
                        
                        <!-- Sidebar Footer -->
                        <VBox spacing="10.0">
                            <padding>
                                <Insets bottom="30.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>
                                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" styleClass="btn-danger" text="Log Out" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
                
                <!-- Main Content Pane -->
                <StackPane fx:id="contentPane" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                    </padding>
                    <children>
                        
                        <!-- Panel 1: Profile & Portal Overview -->
                        <VBox fx:id="panePortal" spacing="25.0">
                            <children>
                                <Label styleClass="title-text" text="Student Profile Overview" />
                                
                                <HBox spacing="25.0">
                                    <children>
                                        <!-- Profile Detail Card -->
                                        <VBox spacing="20.0" styleClass="glass-card" HBox.hgrow="ALWAYS">
                                            <padding>
                                                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                                            </padding>
                                            <children>
                                                <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="Student Information" />
                                                
                                                <HBox spacing="40.0" style="-fx-padding: 10px 0 0 0;">
                                                    <children>
                                                        <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <VBox spacing="3.0">
                                                                    <Label styleClass="text-muted" text="Full Name" />
                                                                    <Label fx:id="lblProfileName" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="N/A" />
                                                                </VBox>
                                                                <VBox spacing="3.0">
                                                                    <Label styleClass="text-muted" text="Unique Student ID" />
                                                                    <Label fx:id="lblProfileId" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="N/A" />
                                                                </VBox>
                                                            </children>
                                                        </VBox>
                                                        
                                                        <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <VBox spacing="3.0">
                                                                    <Label styleClass="text-muted" text="Class Section" />
                                                                    <Label fx:id="lblProfileClass" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="N/A" />
                                                                </VBox>
                                                                <VBox spacing="3.0">
                                                                    <Label styleClass="text-muted" text="Academic Role" />
                                                                    <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #06b6d4;" text="Enrolled Student" />
                                                                </VBox>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                        
                                        <!-- Quick Performance Stats Card -->
                                        <VBox prefWidth="350.0" spacing="20.0" styleClass="glass-card">
                                            <padding>
                                                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                                            </padding>
                                            <children>
                                                <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="Performance Summary" />
                                                
                                                <VBox alignment="CENTER" spacing="5.0" styleClass="stat-box" style="-fx-background-color: rgba(6, 182, 212, 0.05);">
                                                    <children>
                                                        <Label fx:id="lblPortalAttPercent" styleClass="stat-value" text="0.0%" />
                                                        <Label styleClass="stat-label" text="Attendance Rate" />
                                                    </children>
                                                </VBox>
                                                
                                                <HBox spacing="15.0">
                                                    <children>
                                                        <VBox alignment="CENTER" spacing="5.0" styleClass="stat-box" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label fx:id="lblPortalQuizzesTaken" style="-fx-font-size: 24px;" styleClass="stat-value" text="0" />
                                                                <Label styleClass="stat-label" style="-fx-font-size: 10px;" text="Quizzes Taken" />
                                                            </children>
                                                        </VBox>
                                                        <VBox alignment="CENTER" spacing="5.0" styleClass="stat-box" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label fx:id="lblPortalQuizzesPending" style="-fx-font-size: 24px; -fx-text-fill: #ec4899;" styleClass="stat-value" text="0" />
                                                                <Label styleClass="stat-label" style="-fx-font-size: 10px;" text="Quizzes Pending" />
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        
                        <!-- Panel 2: Attendance Records -->
                        <VBox fx:id="paneAttendance" spacing="25.0" visible="false">
                            <children>
                                <Label styleClass="title-text" text="Attendance History" />
                                
                                <HBox spacing="25.0" VBox.vgrow="ALWAYS">
                                    <children>
                                        <!-- Table of Records -->
                                        <VBox spacing="15.0" styleClass="glass-card" HBox.hgrow="ALWAYS">
                                            <padding>
                                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                            </padding>
                                            <children>
                                                <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="Daily Attendance Logs" />
                                                <TableView fx:id="tblAttendanceRecords" VBox.vgrow="ALWAYS">
                                                    <columns>
                                                        <TableColumn fx:id="colStudentAttDate" prefWidth="180.0" text="Date" />
                                                        <TableColumn fx:id="colStudentAttCourse" prefWidth="320.0" text="Course" />
                                                        <TableColumn fx:id="colStudentAttStatus" prefWidth="180.0" text="Status" />
                                                    </columns>
                                                </TableView>
                                            </children>
                                        </VBox>
                                        
                                        <!-- Summary Card -->
                                        <VBox prefWidth="320.0" spacing="20.0" styleClass="glass-card">
                                            <padding>
                                                <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                                            </padding>
                                            <children>
                                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="Attendance Statistics" />
                                                
                                                <VBox spacing="12.0" style="-fx-padding: 10px 0 0 0;">
                                                    <children>
                                                        <HBox alignment="CENTER_LEFT">
                                                            <children>
                                                                <Label styleClass="body-text" text="Total Lectures" />
                                                                <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                                                                    <Label fx:id="lblStatTotalLectures" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="0" />
                                                                </HBox>
                                                            </children>
                                                        </HBox>
                                                        <HBox alignment="CENTER_LEFT">
                                                            <children>
                                                                <Label styleClass="body-text" text="Present Days" />
                                                                <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                                                                    <Label fx:id="lblStatPresentDays" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #10b981;" text="0" />
                                                                </HBox>
                                                            </children>
                                                        </HBox>
                                                        <HBox alignment="CENTER_LEFT">
                                                            <children>
                                                                <Label styleClass="body-text" text="Absent Days" />
                                                                <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                                                                    <Label fx:id="lblStatAbsentDays" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ef4444;" text="0" />
                                                                </HBox>
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        
                        <!-- Panel 3: Quizzes & Assessments -->
                        <VBox fx:id="paneAssessments" spacing="25.0" visible="false">
                            <children>
                                <Label styleClass="title-text" text="Quizzes &amp; Assessments" />
                                
                                <HBox spacing="25.0" VBox.vgrow="ALWAYS">
                                    <!-- Pending Quizzes -->
                                    <VBox spacing="15.0" styleClass="glass-card" HBox.hgrow="ALWAYS">
                                        <padding>
                                            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                        </padding>
                                        <children>
                                            <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ec4899;" text="Assigned / Pending Quizzes" />
                                            <TableView fx:id="tblPendingQuizzes" VBox.vgrow="ALWAYS">
                                                <columns>
                                                    <TableColumn fx:id="colPendQuizTitle" prefWidth="220.0" text="Quiz Title" />
                                                    <TableColumn fx:id="colPendQuizCourse" prefWidth="180.0" text="Course" />
                                                    <TableColumn fx:id="colPendQuizQuestions" prefWidth="100.0" text="Questions" />
                                                    <TableColumn fx:id="colPendQuizTime" prefWidth="100.0" text="Duration" />
                                                    <TableColumn fx:id="colPendQuizAction" prefWidth="120.0" text="Action" />
                                                </columns>
                                            </TableView>
                                        </children>
                                    </VBox>
                                    
                                    <!-- Completed Quizzes -->
                                    <VBox spacing="15.0" styleClass="glass-card" HBox.hgrow="ALWAYS">
                                        <padding>
                                            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                        </padding>
                                        <children>
                                            <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #10b981;" text="Quiz Submission History" />
                                            <TableView fx:id="tblCompletedQuizzes" VBox.vgrow="ALWAYS">
                                                <columns>
                                                    <TableColumn fx:id="colCompQuizTitle" prefWidth="250.0" text="Quiz Title" />
                                                    <TableColumn fx:id="colCompQuizScore" prefWidth="150.0" text="Score" />
                                                    <TableColumn fx:id="colCompQuizDate" prefWidth="200.0" text="Date Submitted" />
                                                </columns>
                                            </TableView>
                                        </children>
                                    </VBox>
                                </HBox>
                            </children>
                        </VBox>
                        
                    </children>
                </StackPane>
            </children>
        </HBox>
    </children>
</AnchorPane>
